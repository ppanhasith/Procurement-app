<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Deal — Admin</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="nav">
    <a href="/" class="nav-logo">
        <span class="dot"></span> Procurement
    </a>
    <ul class="nav-links">
        <li><a href="/">Deals</a></li>
        <li><a href="/admin/orders">All Orders</a></li>
        <li><a href="/logout">Logout</a></li>
    </ul>
</nav>

<div class="admin-form-page">
    <a href="/" class="back-link">&larr; Back to deals</a>
    <h1>Create New Deal</h1>

    <div class="admin-form-card">
        <% if (error) { %>
            <div class="error-msg" style="background:#fff5f5;border-left:3px solid #d71921;padding:0.6rem 0.8rem;font-size:0.85rem;color:#d71921;margin-bottom:1rem;"><%= error %></div>
        <% } %>

        <form method="POST" action="/deals/new">
            <div class="form-group">
                <label>Title</label>
                <input type="text" name="title" required placeholder="e.g. RTX 4060 Graphics Card">
            </div>
            <div class="form-group">
                <label>Description</label>
                <textarea name="description" rows="3" placeholder="Brand new, sealed, shipped from China..."></textarea>
            </div>
            <div class="form-group">
                <label>Source price (your cost)</label>
                <input type="number" step="0.01" name="source_price" placeholder="750.00">
            </div>
            <div class="form-group">
                <label>Sell price (customer pays)</label>
                <input type="number" step="0.01" name="sell_price" required placeholder="950.00">
            </div>
            <div class="form-group">
                <label>Deposit amount</label>
                <input type="number" step="0.01" name="deposit_amount" required placeholder="200.00">
            </div>
            <div class="form-group">
                <label>Total slots</label>
                <input type="number" name="slots_total" required placeholder="3">
            </div>
            <div class="form-group">
                <label>Estimated wait (days)</label>
                <input type="number" name="estimated_wait_days" placeholder="10">
            </div>
            <button type="submit" class="auth-submit">Create Deal</button>
        </form>
    </div>
</div>

</body>
</html>
