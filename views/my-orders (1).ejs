<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Orders — Procurement</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="nav">
    <a href="/" class="nav-logo">
        <span class="dot"></span> Procurement
    </a>
    <ul class="nav-links">
        <li><a href="/">Deals</a></li>
        <li><a href="/my-orders" class="active">My Orders</a></li>
        <% if (user.is_admin) { %>
            <li><a href="/deals/new">+ New Deal</a></li>
            <li><a href="/admin/orders">All Orders</a></li>
        <% } %>
        <li><a href="/logout">Logout</a></li>
    </ul>
</nav>

<section class="section">
    <a href="/" class="back-link">&larr; Back to deals</a>

    <div class="section-header">
        <h2>My Orders</h2>
    </div>

    <% if (orders.length === 0) { %>
        <div class="empty-state">
            <div class="empty-icon">[ ]</div>
            <p>You haven't reserved anything yet.</p>
            <p><a href="/" style="color:#d71921;">Browse available deals</a></p>
        </div>
    <% } else { %>
        <div class="orders-list">
            <% orders.forEach(order => { %>
                <div class="order-card">
                    <h2><%= order.title %></h2>
                    <div class="order-meta">
                        <span class="deal-tag price">$<%= order.sell_price %></span>
                        <span class="deal-tag">Deposit: $<%= order.deposit_amount %></span>
                    </div>
                    <p>Status: <span class="status-tag <%= order.status %>"><%= order.status.replace(/_/g, ' ') %></span></p>
                    <p style="color:#888;font-size:0.85rem;margin-top:0.5rem;">Reserved: <%= new Date(order.created_at).toLocaleDateString() %></p>
                </div>
            <% }) %>
        </div>
    <% } %>
</section>

<footer class="footer">
    <p>Procurement Deals &mdash; Phnom Penh, Cambodia</p>
</footer>

</body>
</html>
