<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=], initial-scale=1.0">
    <title>My Orders</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header>
        <h1>My Orders</h1>
        <p><a href="/">Back to deals</a> | Welcome, <%= user.name %>!</p>
    </header>
    <main>
        <% if (orders.length === 0) { %>
            <p>You haven't reserved anything yet.</p>
        <% } else { %>
            <% orders.forEach(order => { %>
                <div class="order-card">
                    <h2><%= order.title %></h2>
                    <p>Price: $<%= order.sell_price %> | Deposit: $<%= order.deposit_amount %></p>
                    <p>Status: <span class="status-tag status-<%= order.status %>"><%= order.status.replace('_', ' ') %></span></p>
                    <p>Reserved on: <%= new Date(order.created_at).toLocaleDateString() %></p>
                    </div>
            <% }) %>
        <% } %>
    </main>
</body>
</html>